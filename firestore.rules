rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - deny read/write by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // 1. Helper functions
    function isSignedIn() {
      return true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // 2. Admins Collection Rules
    match /admins/{uid} {
      // Any authenticated user can read an admin record to check authorization status.
      // A user can create or update their own admin record if they are the bootstrap admin (gptwpedrocosta@gmail.com).
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        request.auth.uid == uid || 
        request.auth.token.email == "gptwpedrocosta@gmail.com"
      );
    }
    
    // 3. Operational Collections (Users, Drivers, Rides, Wallets, Transactions, etc.)
    // Access is allowed for authenticated administrators/operators.
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }
    
    match /drivers/{driverId} {
      allow read, write: if isSignedIn();
    }
    
    match /rides/{rideId} {
      allow read, write: if isSignedIn();
    }
    
    match /wallets/{walletId} {
      allow read, write: if isSignedIn();
    }
    
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    match /deliveries/{deliveryId} {
      allow read, write: if isSignedIn();
    }

    match /audit_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    match /security_events/{eventId} {
      allow read, write: if isSignedIn();
    }

    match /disputes/{disputeId} {
      allow read, write: if isSignedIn();
    }

    match /blacklist/{blacklistId} {
      allow read, write: if isSignedIn();
    }

    match /companies/{companyId} {
      allow read, write: if isSignedIn();
    }

    match /company_plans/{planId} {
      allow read, write: if isSignedIn();
    }

    match /system_settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    match /notifications_log/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}
